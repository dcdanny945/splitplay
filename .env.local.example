# Copy this file to ".env.local" and fill in your real values.
# .env.local is gitignored — never commit it.

# ---- Supabase (Project Settings -> API) ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...           # anon public key (frontend-safe)
SUPABASE_SERVICE_KEY=eyJ...                    # service_role key (SECRET, server only)

# ---- Stripe (Developers -> API keys) ----
STRIPE_SECRET_KEY=sk_test_...                  # SECRET, server only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_... # publishable (frontend-safe)
STRIPE_WEBHOOK_SECRET=whsec_...                # from the webhook you create later

# ---- Resend (confirmation email — resend.com -> API Keys) ----
RESEND_API_KEY=re_...
# Until you verify your own domain, use Resend's sandbox sender:
EMAIL_FROM=SplitPlay <onboarding@resend.dev>

# ---- Admin login ----
ADMIN_PASSWORD=change-this-to-something-strong
ADMIN_SESSION_SECRET=run-the-openssl-command-below-to-generate-one

# ---- App / Cron ----
NEXT_PUBLIC_URL=http://localhost:3000          # your deployed URL in production
CRON_SECRET=run-the-openssl-command-below-to-generate-one

# Tip: generate a random secret with:  openssl rand -hex 32
